# Docker Compose Environment Variables
# Copy this file to .env and customize for your environment

# ======================
# Database Configuration
# ======================
POSTGRES_DB=task_manager_db
POSTGRES_USER=root
POSTGRES_PASSWORD=postgres
PGDATA=/var/lib/postgresql/data/pgdata

# ======================
# Keycloak Configuration
# ======================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_DB=postgres
KC_DB_SCHEMA=public
KC_HTTP_PORT=8080

# ======================
# Backend Configuration
# ======================
SPRING_PROFILES_ACTIVE=docker
POSTGRESQL_HOST=postgres
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=task_manager_db
POSTGRESQL_USER=root
POSTGRESQL_PASSWORD=postgres
FILE_UPLOAD_DIR=/app/uploads

# JVM Configuration
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:InitialRAMPercentage=50.0

# ======================
# Frontend Configuration
# ======================
NODE_ENV=production
API_URL=http://localhost:8082/task-manager
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=task-manager
KEYCLOAK_CLIENT_ID=task-manager-client

# ======================
# Container Resources (Optional)
# ======================
# Uncomment to set memory limits
# BACKEND_MEMORY=2g
# FRONTEND_MEMORY=512m
# KEYCLOAK_MEMORY=1g
# POSTGRES_MEMORY=1g

