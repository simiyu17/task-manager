# Domain Configuration (REQUIRED)
DOMAIN=localhost

# Let's Encrypt Configuration (REQUIRED for SSL)
ACME_EMAIL=your-email@example.com

# PostgreSQL Database Configuration for API
POSTGRESQL_HOST=host.docker.internal
POSTGRESQL_PORT=5433
POSTGRESQL_DATABASE=task_man_db
POSTGRESQL_USER=root
POSTGRESQL_PASSWORD=postgres

# Keycloak Database Configuration
KC_DB_HOST=host.docker.internal
KC_DB_NAME=keycloak
KC_DB_PORT=5433
KC_DB_USERNAME=root
KC_DB_PASSWORD=postgres

# Keycloak Admin Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=task-manager
KEYCLOAK_API_CLIENT_ID=task-manager-api-client
KEYCLOAK_UI_CLIENT_ID=task-manager-ui-client
KEY_CLOAK_ISSUER_URI=https://${DOMAIN}/auth/realms/${KEYCLOAK_REALM}
KEYCLOAK_AUTH_SERVER_URL=https://${DOMAIN}/auth/

# UI configurations
ANGULAR_API_BASE_URL=https://${DOMAIN}/api/

# File Upload Configuration
FILE_UPLOAD_DIR=./task-uploads
GITHUB_TOKEN=sample

