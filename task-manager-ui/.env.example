# Domain Configuration (REQUIRED)
DOMAIN=your-domain.com

# Let's Encrypt Configuration (REQUIRED for SSL)
ACME_EMAIL=your-email@example.com

# PostgreSQL Database Configuration
# External PostgreSQL on host (use init-postgres.sh to setup)
POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=taskmanager
POSTGRESQL_USER=taskmanager
POSTGRESQL_PASSWORD=taskmanager_password

# Keycloak Database Configuration
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak_password

# Keycloak Admin Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=task-manager
KEYCLOAK_RESOURCE_API=task-manager-api-client
KEYCLOAK_RESOURCE_UI=task-manager-ui-client

# Keycloak URLs
# For Docker: http://keycloak:8080
# For Local Dev: http://localhost:8080
AUTH_BASE_URL=http://keycloak:8080
AUTH_REALM_NAME=task-manager
AUTH_CLIENT_ID=task-manager-ui-client

# Spring Boot Application Configuration
SPRING_PROFILES_ACTIVE=docker
SERVER_PORT=8082
SERVER_CONTEXT_PATH=/task-manager

# API Configuration
# For Docker: http://task-manager-api:8082/task-manager/api/v1
# For Local Dev: http://localhost:8082/task-manager/api/v1
API_BASE_URL=http://task-manager-api:8082/task-manager/api/v1

# File Upload Configuration
FILE_UPLOAD_DIR=./uploads

# Database Connection Pool Settings (HikariCP)
DB_HIKARI_MAX_POOL_SIZE=20
DB_HIKARI_MIN_IDLE=10
DB_HIKARI_CONNECTION_TIMEOUT=60000
DB_HIKARI_IDLE_TIMEOUT=600000
DB_HIKARI_MAX_LIFETIME=1800000

# Note: External PostgreSQL is accessed via host.docker.internal:5432
# Ensure your PostgreSQL allows connections from Docker containers
# Run ./init-postgres.sh to setup databases and permissions
